  <h4 id="id-(4.3)RKE2DeploymentinHighAvailabilityWithNginx/HAProxy-Step2:PrepareFirstControlPlane"><span id="RKE2DeploymentinHighAvailabilityWithNginx/HAProxy-Step2:PrepareFirstControlPlane"></span>Step 2: Prepare First Control Plane
   <i18n-message i18nkey="clipboard.copyLink.label" attribute="description">
    <copy-clipboard class="anchor-copy-button" value="https://docs.expertflow.com/cx/4.3/rke2-deployment-in-high-availability-with-nginx-ha#id-(4.3)RKE2DeploymentinHighAvailabilityWithNginx/HAProxy-Step2:PrepareFirstControlPlane">
     <svg role="img" aria-hidden="true" data-component="icon" class="icon icon-link copy-headline-link-icon">
      <use href="/__theme/b_8ca5a7d7-80f3-41c8-bea7-75cce14ad14f/scroll-sites-help-center-theme/41/icons.svg#link"></use>
