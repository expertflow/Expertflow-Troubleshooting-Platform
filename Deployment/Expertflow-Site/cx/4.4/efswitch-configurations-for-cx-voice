<h2 id="Configure-IVR-scripts-and-recordings" style=""><span id="EFSwitchConfigurationsforCXVoice-ConfigureIVRscriptsandrecordings"></span>Configure IVR scripts and recordings
 <i18n-message i18nkey="clipboard.copyLink.label" attribute="description">
  <copy-clipboard class="anchor-copy-button" value="https://docs.expertflow.com/cx/4.4/efswitch-configurations-for-cx-voice#Configure-IVR-scripts-and-recordings">
   <svg role="img" aria-hidden="true" data-component="icon" class="icon icon-link copy-headline-link-icon">
    <use href="/__theme/b_8ca5a7d7-80f3-41c8-bea7-75cce14ad14f/scroll-sites-help-center-theme/41/icons.svg#link"></use>
   </svg>
