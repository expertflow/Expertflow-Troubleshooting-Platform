      </colgroup>
      <tbody>
       <tr>
        <th>
         <p><strong>Field</strong></p>
        </th>
        <th>
         <p><strong>Description</strong></p>
        </th>
       </tr>
       <tr>
        <th style="--bg-color: #f0f0f0">
         <p><strong>Label</strong></p>
        </th>
        <td>
         <p>Specify a reason label. This label will be displayed in the reasons list to agents in AgentDesk.</p>
        </td>
       </tr>
       <tr>
        <th>
         <p><strong>Type</strong></p>
        </th>
        <td>
         <p>Select a type from one of the following:</p>
         <p><code>Not Ready</code> | <code>Logout</code></p>
        </td>
       </tr>
       <tr>
        <th>
         <p><strong>Description</strong></p>
        </th>
        <td>
         <p>An optional description for the reason</p>
        </td>
       </tr>
      </tbody>
     </table>
    </div>
   </table-sort>
  </scroll-shadow>
 </table-expand>
</div> 
<div class="theme-block-image">
