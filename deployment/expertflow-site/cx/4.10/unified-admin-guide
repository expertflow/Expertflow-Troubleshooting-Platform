<h3 id="Create-a-new-team"><span id="UnifiedAdminGuide-Createanewteam"></span>Create a new team
 <i18n-message i18nkey="clipboard.copyLink.label" attribute="description">
  <copy-clipboard class="anchor-copy-button" value="https://docs.expertflow.com/cx/4.10/unified-admin-guide#Create-a-new-team">
