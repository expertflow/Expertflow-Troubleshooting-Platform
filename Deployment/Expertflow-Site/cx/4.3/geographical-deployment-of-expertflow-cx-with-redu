  <h2 id="id-(4.3)GeographicalDeploymentofExpertflowCXwithRedundancy-ExpertflowCXInternalComponents"><span id="GeographicalDeploymentofExpertflowCXwithRedundancy-ExpertflowCXInternalComponents"></span>Expertflow CX Internal Components
   <i18n-message i18nkey="clipboard.copyLink.label" attribute="description">
    <copy-clipboard class="anchor-copy-button" value="https://docs.expertflow.com/cx/4.3/geographical-deployment-of-expertflow-cx-with-redu#id-(4.3)GeographicalDeploymentofExpertflowCXwithRedundancy-ExpertflowCXInternalComponents">
     <svg role="img" aria-hidden="true" data-component="icon" class="icon icon-link copy-headline-link-icon">
