     </svg>
    </copy-clipboard>
   </i18n-message></h3>
  <h4 id="id-(4.3)RKE2DeploymentinHighAvailabilityWithNginx/HAProxy-Load-BalancerNode"><span id="RKE2DeploymentinHighAvailabilityWithNginx/HAProxy-Load-BalancerNode"></span>Load-Balancer Node
   <i18n-message i18nkey="clipboard.copyLink.label" attribute="description">
    <copy-clipboard class="anchor-copy-button" value="https://docs.expertflow.com/cx/4.3/rke2-deployment-in-high-availability-with-nginx-ha#id-(4.3)RKE2DeploymentinHighAvailabilityWithNginx/HAProxy-Load-BalancerNode">
