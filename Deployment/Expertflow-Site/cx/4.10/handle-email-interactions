<h2 id="Initiate-Outbound-Email-Communication"><span id="HandleEmailInteractions-InitiateOutboundEmailCommunication"></span>Initiate Outbound Email Communication
 <i18n-message i18nkey="clipboard.copyLink.label" attribute="description">
  <copy-clipboard class="anchor-copy-button" value="https://docs.expertflow.com/cx/4.10/handle-email-interactions#Initiate-Outbound-Email-Communication">
   <svg role="img" aria-hidden="true" data-component="icon" class="icon icon-link copy-headline-link-icon">
