<h3 id="id-(4.3)Forms-Customersurveypolls"><span id="Forms-Customersurveypolls"></span>Customer survey polls
 <i18n-message i18nkey="clipboard.copyLink.label" attribute="description">
  <copy-clipboard class="anchor-copy-button" value="https://docs.expertflow.com/cx/4.3/forms#id-(4.3)Forms-Customersurveypolls">
   <svg role="img" aria-hidden="true" data-component="icon" class="icon icon-link copy-headline-link-icon">
