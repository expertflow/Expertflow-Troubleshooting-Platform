<h2 id="id-(4.3)Forms-FormUsecases"><span id="Forms-FormUsecases"></span>Form Use cases
 <i18n-message i18nkey="clipboard.copyLink.label" attribute="description">
  <copy-clipboard class="anchor-copy-button" value="https://docs.expertflow.com/cx/4.3/forms#id-(4.3)Forms-FormUsecases">
