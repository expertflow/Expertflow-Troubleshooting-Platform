<h3 id="id-(3.15)MREArchitecture&amp;CommunicationFlow-Limitations" style=""><span id="MREArchitecture&amp;amp;CommunicationFlow-Limitations"></span><strong>Limitations</strong>
 <i18n-message i18nkey="clipboard.copyLink.label" attribute="description">
  <copy-clipboard class="anchor-copy-button" value="https://docs.expertflow.com/chat/3.15/mre-architecture-communication-flow#id-(3.15)MREArchitecture&amp;amp;CommunicationFlow-Limitations">
