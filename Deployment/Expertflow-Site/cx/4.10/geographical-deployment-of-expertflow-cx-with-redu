<h3 id="Step-2:-Blueprint-for-Node-Affinity-on-CX-components"><span id="GeographicalDeploymentofExpertflowCXwithRedundancy-Step2:BlueprintforNodeAffinityonCXcomponents"></span>Step 2: Blueprint for Node Affinity on CX components&nbsp;
 <i18n-message i18nkey="clipboard.copyLink.label" attribute="description">
  <copy-clipboard class="anchor-copy-button" value="https://docs.expertflow.com/cx/4.10/geographical-deployment-of-expertflow-cx-with-redu#Step-2:-Blueprint-for-Node-Affinity-on-CX-components">
